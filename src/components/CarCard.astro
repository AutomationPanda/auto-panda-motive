---
import type { CollectionEntry } from "astro:content";
import { resolveImage } from "../utils/image";
import { withBase } from "../utils/url";

interface Props {
  car: CollectionEntry<"cars">;
}

const { car } = Astro.props;
const { name, hook, heroImage, qrSlug, section } = car.data;
const isPlaceholder = heroImage.includes("placeholder");
---

<a class="car-card" data-mode={isPlaceholder ? "fallback" : "cutout"} href={withBase(`/cars/${qrSlug}/`)}>
  <div class="car-card__image-wrap">
    <img src={resolveImage(heroImage)} alt={name} loading="lazy" />
  </div>
  <div class="car-card-body">
    {section === "memory-lane" && <span class="section-label">Memory Lane</span>}
    <h3>{name}</h3>
    <p>{hook}</p>
  </div>
</a>

<style>
  .car-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: transparent;
  }

  .car-card:hover h3 {
    color: var(--color-accent);
  }

  .car-card__image-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    min-height: 10rem;
    padding: 0.25rem 0.5rem 0;
    line-height: 0;
    text-align: center;
  }

  .car-card img {
    width: auto;
    max-width: 100%;
    max-height: 11rem;
    height: auto;
    object-fit: contain;
    display: inline-block;
    vertical-align: bottom;
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .car-card[data-mode="cutout"] img {
    filter: drop-shadow(0 0.5rem 1rem rgba(0, 0, 0, 0.15));
  }

  .car-card[data-mode="fallback"] img {
    filter: drop-shadow(0 0.25rem 0.5rem rgba(0, 0, 0, 0.08));
  }

  .car-card:hover img {
    transform: scale(1.04) translateY(-3px);
  }

  .car-card:hover[data-mode="cutout"] img {
    filter: drop-shadow(0 0.85rem 1.75rem rgba(0, 0, 0, 0.3));
  }

  .car-card:hover[data-mode="fallback"] img {
    filter: drop-shadow(0 0.75rem 1.5rem rgba(0, 0, 0, 0.22));
  }

  @media (prefers-reduced-motion: reduce) {
    .car-card img {
      transition: filter 0.2s ease;
    }

    .car-card:hover img {
      transform: none;
    }

    .car-card-body {
      transition: none;
    }

    .car-card:hover .car-card-body {
      transform: none;
    }
  }

  .car-card-body {
    padding: 0.75rem 0.5rem 0;
    transition: transform 0.2s ease;
  }

  .car-card:hover .car-card-body {
    transform: translateY(-2px);
  }

  .car-card-body h3 {
    margin: 0.25rem 0;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .car-card-body p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .car-card:hover .car-card-body p {
    color: var(--color-text);
  }
</style>
