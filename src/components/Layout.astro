---
import "../styles/global.css";
import Footer from "./Footer.astro";
import { withBase } from "../utils/url";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Stories and pictures from the Auto Panda Motive garage.",
  image = withBase("/images/logo/panda_tire.png"),
} = Astro.props;
const siteName = "Auto Panda Motive";
const pageTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const faviconLight = withBase("/favicon.svg");
const faviconDark = withBase("/favicon-dark.svg");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link
      rel="icon"
      type="image/svg+xml"
      href={faviconLight}
    />
    <script is:inline define:vars={{ faviconLight, faviconDark }}>
      (function () {
        function logoFor(theme) {
          return theme === "dark" ? faviconDark : faviconLight;
        }

        function applyTheme(theme) {
          document.documentElement.setAttribute("data-theme", theme);
          document.querySelectorAll(".site-logo-icon").forEach(function (icon) {
            icon.src = logoFor(theme);
          });
        }

        var stored = localStorage.getItem("theme");
        var theme = "light";
        if (stored === "light" || stored === "dark") {
          theme = stored;
        } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          theme = "dark";
        }
        applyTheme(theme);
        window.__applySiteTheme = applyTheme;
      })();
    </script>
    <style is:inline>
      html {
        background-color: #ffffff;
        color: #1a1a1a;
      }

      html[data-theme="dark"] {
        background-color: #0a0a0a;
        color: #f5f5f5;
      }
    </style>
    <slot name="head" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="Main">
        <a class="logo" href={withBase("/")}>
          <img class="logo__icon site-logo-icon" src={faviconLight} alt="" width="28" height="28" />
          <span class="logo__text">{siteName}</span>
        </a>
        <div class="nav-links" id="nav-menu">
          <a href={withBase("/")}>Home</a>
          <a href={withBase("/garage/")}>The Garage</a>
          <a href={withBase("/memory-lane/")}>Memory Lane</a>
          <a href={withBase("/about/")}>About</a>
        </div>
        <div class="nav-actions">
          <button
            type="button"
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Switch to dark mode"
            aria-pressed="false"
          >
            ☾
          </button>
          <button
            type="button"
            class="nav-toggle"
            id="nav-toggle"
            aria-controls="nav-menu"
            aria-expanded="false"
            aria-label="Open menu"
          >
            <span class="nav-toggle__bar" aria-hidden="true"></span>
            <span class="nav-toggle__bar" aria-hidden="true"></span>
            <span class="nav-toggle__bar" aria-hidden="true"></span>
          </button>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        var toggle = document.getElementById("theme-toggle");
        if (!toggle) return;

        function syncToggle() {
          var isDark = document.documentElement.getAttribute("data-theme") === "dark";
          toggle.textContent = isDark ? "☀" : "☾";
          toggle.setAttribute("aria-label", isDark ? "Switch to light mode" : "Switch to dark mode");
          toggle.setAttribute("aria-pressed", String(isDark));
        }

        syncToggle();

        if (typeof window.__applySiteTheme === "function") {
          window.__applySiteTheme(document.documentElement.getAttribute("data-theme") || "light");
        }

        toggle.addEventListener("click", function () {
          var isDark = document.documentElement.getAttribute("data-theme") === "dark";
          var next = isDark ? "light" : "dark";
          if (typeof window.__applySiteTheme === "function") {
            window.__applySiteTheme(next);
          } else {
            document.documentElement.setAttribute("data-theme", next);
          }
          localStorage.setItem("theme", next);
          syncToggle();
        });

        var navToggle = document.getElementById("nav-toggle");
        var navMenu = document.getElementById("nav-menu");

        function setNavOpen(open) {
          if (!navToggle || !navMenu) return;
          navToggle.setAttribute("aria-expanded", String(open));
          navToggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
          navMenu.classList.toggle("is-open", open);
        }

        if (navToggle && navMenu) {
          navToggle.addEventListener("click", function () {
            setNavOpen(navToggle.getAttribute("aria-expanded") !== "true");
          });

          navMenu.querySelectorAll("a").forEach(function (link) {
            link.addEventListener("click", function () {
              setNavOpen(false);
            });
          });

          document.addEventListener("keydown", function (event) {
            if (event.key === "Escape") {
              setNavOpen(false);
            }
          });
        }
      })();
    </script>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .nav {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    min-height: var(--nav-height);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    font-size: clamp(0.875rem, 2.8vw, 1.0625rem);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: var(--color-accent);
  }

  .logo__icon {
    width: 1.75rem;
    height: 1.75rem;
    object-fit: contain;
    flex-shrink: 0;
  }

  .logo__text {
    line-height: 1.1;
  }

  .nav-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .nav-links {
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 0.25rem;
    position: absolute;
    top: 100%;
    left: 50%;
    z-index: 1;
    width: 100vw;
    margin: 0;
    padding: 0.75rem 1rem 1rem;
    transform: translateX(-50%);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08);
  }

  .nav-links.is-open {
    display: flex;
  }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.25rem;
    flex-shrink: 0;
    width: 2rem;
    height: 1.75rem;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg-alt);
    cursor: pointer;
  }

  .nav-toggle:hover {
    border-color: var(--color-accent);
  }

  .nav-toggle__bar {
    display: block;
    width: 1rem;
    height: 2px;
    margin-inline: auto;
    background: var(--color-accent);
    border-radius: 1px;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 1.75rem;
    padding: 0;
    font-size: 0.9rem;
    line-height: 1;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg-alt);
    color: var(--color-accent);
    cursor: pointer;
  }

  .theme-toggle:hover {
    border-color: var(--color-accent);
  }

  .nav-links a {
    text-decoration: none;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    padding: 0.625rem 0.75rem;
    border-radius: 4px;
  }

  .nav-links a:hover {
    background: var(--color-bg-alt);
  }

  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }

    .nav-links {
      display: flex;
      flex-direction: row;
      align-items: center;
      position: static;
      width: auto;
      margin-left: auto;
      padding: 0;
      transform: none;
      background: transparent;
      border-bottom: none;
      box-shadow: none;
      gap: 1.25rem;
    }

    .nav-links a {
      padding: 0.25rem 0.5rem;
      font-size: 0.9rem;
    }
  }
</style>
