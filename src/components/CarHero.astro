---
import type { CollectionEntry } from "astro:content";
import { resolveImage } from "../utils/image";

interface Props {
  car: CollectionEntry<"cars">;
}

const { car } = Astro.props;
const { name, year, make, model, section, heroImage } = car.data;
const resolvedImage = resolveImage(heroImage);
const isPlaceholder = heroImage.includes("placeholder");
---

<section class="car-hero" data-mode={isPlaceholder ? "fallback" : "cutout"}>
  <div class="car-hero__canvas">
    {section === "memory-lane" && (
      <div class="container car-hero__label">
        <span class="section-label">Memory Lane</span>
      </div>
    )}
    <div class="car-hero__composition">
      <h1 class="car-hero__statement">
        <span class="car-hero__line">{year} {make}</span>
        <span class="car-hero__line">{model}</span>
      </h1>
      <div class="car-hero__image-wrap">
        <img
          class="car-hero__image"
          src={resolvedImage}
          alt={name}
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .car-hero {
    padding-bottom: 1.5rem;
  }

  .car-hero__canvas {
    padding-top: 1rem;
  }

  .car-hero__label {
    margin-bottom: 0.5rem;
  }

  .car-hero__composition {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .car-hero__statement {
    position: relative;
    z-index: 2;
    align-self: stretch;
    width: 100%;
    margin: 0;
    padding-inline: clamp(1rem, 4vw, 2rem);
    text-align: center;
    font-weight: 900;
    font-size: clamp(2.75rem, 10vw + 0.75rem, 6.25rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .car-hero__line {
    display: block;
  }

  .car-hero__image-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 820px;
    margin-inline: auto;
    margin-top: clamp(-1.75rem, -4vw, -0.5rem);
    line-height: 0;
    text-align: center;
  }

  .car-hero__image {
    width: auto;
    max-width: 100%;
    height: auto;
    display: inline-block;
    vertical-align: bottom;
  }

  .car-hero[data-mode="cutout"] .car-hero__image-wrap {
    transform: translateY(-6%);
  }

  .car-hero[data-mode="cutout"] .car-hero__image {
    filter: drop-shadow(0 1rem 2rem rgba(0, 0, 0, 0.18));
  }

  .car-hero[data-mode="fallback"] .car-hero__image-wrap {
    margin-top: 0.75rem;
    width: min(100% - 2rem, 700px);
    transform: none;
  }

  .car-hero[data-mode="fallback"] .car-hero__image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: contain;
    background: var(--color-bg-alt);
  }
</style>

<style is:global>
  h1.car-hero__statement {
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }
</style>
