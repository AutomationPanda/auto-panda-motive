---
import type { CollectionEntry } from "astro:content";
import { getHeroAspectRatio, getHeroDimensions } from "../data/hero-dimensions";
import { resolveImage } from "../utils/image";
import HeroTitle from "./HeroTitle.astro";
import HeroRevealImage from "./HeroRevealImage.astro";

interface Props {
  car: CollectionEntry<"cars">;
}

const { car } = Astro.props;
const { name, year, make, model, section, heroImage } = car.data;
const resolvedImage = resolveImage(heroImage);
const heroDimensions = getHeroDimensions(heroImage);
const heroAspectRatio = getHeroAspectRatio(heroImage);
const isPlaceholder = heroImage.includes("placeholder");
---

<section class="car-hero" data-mode={isPlaceholder ? "fallback" : "cutout"}>
  <div class="car-hero__canvas">
    {section === "memory-lane" && (
      <div class="container car-hero__label">
        <span class="section-label">Memory Lane</span>
      </div>
    )}
    <div class="car-hero__composition">
      <HeroTitle lines={[ `${year} ${make}`, model ]} />
      <div
        class="car-hero__image-wrap"
        style={!isPlaceholder && heroAspectRatio
          ? `aspect-ratio: ${heroAspectRatio}`
          : undefined}
      >
        <HeroRevealImage
          src={resolvedImage}
          alt={name}
          width={heroDimensions?.width}
          height={heroDimensions?.height}
          class="car-hero__image"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .car-hero {
    padding-bottom: 1.5rem;
  }

  .car-hero__canvas {
    padding-top: 1rem;
  }

  .car-hero__label {
    margin-bottom: 0.5rem;
  }

  .car-hero__composition {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .car-hero__image-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 820px;
    margin-inline: auto;
    margin-top: clamp(-1.75rem, -4vw, -0.5rem);
    line-height: 0;
    text-align: center;
  }

  .car-hero :global(.car-hero__image) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    display: block;
  }

  .car-hero[data-mode="cutout"] .car-hero__image-wrap {
    transform: translateY(-1.5rem);
  }

  .car-hero[data-mode="cutout"] :global(.car-hero__image) {
    filter: drop-shadow(0 1rem 2rem rgba(0, 0, 0, 0.18));
  }

  .car-hero[data-mode="fallback"] .car-hero__image-wrap {
    margin-top: 0.75rem;
    width: min(100% - 2rem, 700px);
    transform: none;
    aspect-ratio: 16 / 10;
  }

  .car-hero[data-mode="fallback"] :global(.car-hero__image) {
    object-fit: contain;
    background: var(--color-bg-alt);
  }
</style>
