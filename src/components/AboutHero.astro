---
import { resolveImage } from "../utils/image";
import HeroTitle from "./HeroTitle.astro";

const heroImage = "/images/hero/about.webp";
const resolvedImage = resolveImage(heroImage);
---

<section class="about-hero">
  <div class="about-hero__canvas">
    <div class="about-hero__composition">
      <HeroTitle title="About" />
      <div class="about-hero__image-wrap">
        <img
          class="about-hero__image"
          src={resolvedImage}
          alt="Pandy with a classic car"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .about-hero {
    padding-bottom: 1.5rem;
  }

  .about-hero__canvas {
    padding-top: 1rem;
  }

  .about-hero__composition {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .about-hero__image-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 820px;
    margin-inline: auto;
    margin-top: clamp(-1.75rem, -4vw, -0.5rem);
    line-height: 0;
    text-align: center;
    transform: translateY(-6%);
  }

  .about-hero__image {
    width: auto;
    max-width: 100%;
    height: auto;
    display: inline-block;
    vertical-align: bottom;
    filter: drop-shadow(0 1rem 2rem rgba(0, 0, 0, 0.18));
  }
</style>
