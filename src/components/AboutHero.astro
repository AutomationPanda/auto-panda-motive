---
import { resolveImage } from "../utils/image";

const heroImage = "/images/hero/about.webp";
const resolvedImage = resolveImage(heroImage);
---

<section class="about-hero">
  <div class="about-hero__canvas">
    <div class="about-hero__composition">
      <h1 class="about-hero__statement">About</h1>
      <div class="about-hero__image-wrap">
        <img
          class="about-hero__image"
          src={resolvedImage}
          alt="Pandy with a classic car"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .about-hero {
    padding-bottom: 1.5rem;
  }

  .about-hero__canvas {
    padding-top: 1rem;
  }

  .about-hero__composition {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .about-hero__statement {
    position: relative;
    z-index: 2;
    align-self: stretch;
    width: 100%;
    margin: 0;
    padding-inline: clamp(1rem, 4vw, 2rem);
    text-align: center;
    font-weight: 900;
    font-size: clamp(2.75rem, 10vw + 0.75rem, 6.25rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .about-hero__image-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 820px;
    margin-inline: auto;
    margin-top: clamp(-1.75rem, -4vw, -0.5rem);
    line-height: 0;
    text-align: center;
    transform: translateY(-6%);
  }

  .about-hero__image {
    width: auto;
    max-width: 100%;
    height: auto;
    display: inline-block;
    vertical-align: bottom;
    filter: drop-shadow(0 1rem 2rem rgba(0, 0, 0, 0.18));
  }
</style>

<style is:global>
  h1.about-hero__statement {
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }
</style>
