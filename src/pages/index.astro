---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import CarCard from "../components/CarCard.astro";
import HomeHero from "../components/HomeHero.astro";

const garageCars = (await getCollection("cars"))
  .filter((car) => car.data.section === "garage")
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const memoryLaneCars = (await getCollection("cars"))
  .filter((car) => car.data.section === "memory-lane")
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const heroImage = "https://cdn.jsdelivr.net/gh/AutomationPanda/auto-panda-motive-photos/images/pages/home.jpeg";
const heroImageAlt = "1970 Volkswagen Beetle and Volkswagen Bus in the driveway";
---

<Layout title="Auto Panda Motive">
  <HomeHero
    headlinePrimary="Every car has a story."
    headlineSecondary="These are the ones that are special to me."
    imageSrc={heroImage}
    imageAlt={heroImageAlt}
  />
  <div class="container page">
    <section class="car-section">
      <h2>The Garage</h2>
      <p class="intro">The cars I currently own.</p>
      <div class="car-grid">
        {garageCars.map((car) => <CarCard car={car} />)}
      </div>
    </section>
    <section class="car-section">
      <h2>Memory Lane</h2>
      <p class="intro">The cars I once loved but no longer own.</p>
      <div class="car-grid">
        {memoryLaneCars.map((car) => <CarCard car={car} />)}
      </div>
    </section>
  </div>
</Layout>

<style>
  .car-section + .car-section {
    margin-top: 3.5rem;
  }
</style>
