---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "../../components/Layout.astro";
import CarHero from "../../components/CarHero.astro";
import PhotoGallery from "../../components/PhotoGallery.astro";
import StoryTimeline from "../../components/StoryTimeline.astro";
import { renderMarkdownBody } from "../../markdown";
import { resolveImage } from "../../utils/image";

interface Props {
  car: CollectionEntry<"cars">;
}

export async function getStaticPaths() {
  const cars = await getCollection("cars");
  return cars.map((car) => ({
    params: { slug: car.data.qrSlug },
    props: { car },
  }));
}

const { car } = Astro.props as Props;
const allStories = await getCollection("stories");
const carStories = allStories.filter((story) => story.id.startsWith(`${car.data.qrSlug}/`));

const overviewHtml = car.body ? await renderMarkdownBody(car.body, car.data) : "";
const heroImage = resolveImage(car.data.heroImage);
---

<Layout title={car.data.name} description={car.data.hook}>
  <link
    slot="head"
    rel="preload"
    as="image"
    href={heroImage}
    fetchpriority="high"
  />
  <article class="car-page">
    <CarHero car={car} />
    <div class="container content">
      {overviewHtml && <div class="overview" set:html={overviewHtml} />}
      <PhotoGallery images={car.data.gallery} alt={car.data.name} />
      {carStories.length > 0 ? (
        <StoryTimeline stories={carStories} />
      ) : (
        !overviewHtml && <p class="stories-empty">Stories coming soon.</p>
      )}
    </div>
  </article>
</Layout>

<style>
  .content {
    padding: 1.25rem 0 3rem;
    display: grid;
    gap: 1.5rem;
  }

  .overview {
    color: var(--color-text-muted);
  }

  .stories-empty {
    color: var(--color-text-muted);
  }
</style>
